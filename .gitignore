# Python bytecode and caches
__pycache__/
*.py[cod]
.pytest_cache/

# Virtualenv — recreate with: python -m venv .venv && .venv/bin/pip install -r requirements.txt
.venv/
venv/

# Model binaries — large; download via the setup steps in README.md
voices/
whisper_models/
*.onnx
*.onnx.json

# Generated audio (tests synthesize their own)
test_audio/*
!test_audio/.gitkeep

# Wake-word recordings and processed clips — personal voice data, never committed
samples/
recordings/

# Local experiment/training scripts (machine-specific paths), not part of the published project
experiments/

# Custom-trained wake-word models live here; the binaries are personal (see *.onnx above)
!models/.gitkeep

# Build-process notes, not part of the published project
INVENTORY.txt
HALT_REPORT.md

# Local, non-published config and session cruft
config.local.json
.remember/
.DS_Store
